# Copy this file to .env.local and fill in your real keys.

# Writes the story. Get one at: https://console.anthropic.com  ->  API Keys
ANTHROPIC_API_KEY=your-anthropic-key-here

# Narrates the story aloud with Gemini's voice (free tier, no credit card).
# Get one at: https://aistudio.google.com/apikey
# If left blank, the app falls back to the phone's free built-in voice.
GEMINI_API_KEY=your-gemini-key-here

# Stores saved stories in Supabase (anon key is browser-safe).
NEXT_PUBLIC_SUPABASE_URL=https://ftcdqmrjjooluihysuyc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
